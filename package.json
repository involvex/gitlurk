{
  "name": "gitlurk-desktop",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "bin": {
    "gitlurk": "./packages/cli/src/cli.ts"
  },
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "dev": "bun run --filter @gitlurk/app dev",
    "build": "bun run --filter @gitlurk/shared build && bun run --filter @gitlurk/git build && bun run --filter @gitlurk/gh build && bun run --filter @involvex/gitlurk-desktop build && bun run --filter @gitlurk/app build",
    "publish:cli": "bun run --filter @involvex/gitlurk-desktop prepublishOnly && bunx npm publish --workspace @involvex/gitlurk-desktop",
    "tauri:dev": "bun run --filter @gitlurk/app tauri:dev",
    "tauri:build": "bun run --filter @gitlurk/app tauri:build",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "bun run --filter '*' typecheck",
    "changelog": "bun run scripts/generate-changelog.ts",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/bun": "^1.2.14",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
