# Copy to `.env` in the repo root (never commit `.env`).
# Device Flow only needs GITHUB_CLIENT_ID; the secret is optional and stays in the Rust backend.
# Aliases: GITLURK_GITHUB_* or legacy MYGIT_GITHUB_* (see docs/security.md).

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1/callback
