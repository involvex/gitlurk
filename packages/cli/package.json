{
  "name": "@gitlurk/cli",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "bin": {
    "gitlurk": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
