  },
  "dependencies": {
    "@gitlurk/gh": "workspace:*",
    "@gitlurk/git": "workspace:*",
    "@gitlurk/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
